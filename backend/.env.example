# ─── Base de datos ────────────────────────────────────────────────────────────
# Conexión a PostgreSQL (levantado con docker compose up -d)
DATABASE_URL=postgresql://spike_user:spike_pass@localhost:5433/spike_gpu

# ─── YouTube API v3 ───────────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com → Enable "YouTube Data API v3" → Credentials → API Key
YOUTUBE_API_KEY=AIza...TU_KEY_AQUI

# ─── Ollama (LLM local) ───────────────────────────────────────────────────────
# URL del servidor Ollama (por defecto corre en localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Modelo a usar. Local: qwen2.5:7b | RunPod: qwen2.5:72b o mayor
OLLAMA_MODEL=qwen2.5:7b

# ─── Whisper ──────────────────────────────────────────────────────────────────
# Modelo de transcripción. Local: medium | RunPod: large-v3
WHISPER_MODEL=medium
# Dispositivo. Opciones: cuda (GPU NVIDIA) | cpu
# En RunPod siempre usar cuda. En local usar cpu si no tienes GPU NVIDIA.
WHISPER_DEVICE=cuda

# ─── Control de desarrollo ────────────────────────────────────────────────────
# Si es true, omite la descarga y transcripción y reutiliza lo que ya está en BD.
# Útil para iterar rápido en el análisis LLM sin esperar re-descargas.
SKIP_DOWNLOAD=false

# ─── Entorno ──────────────────────────────────────────────────────────────────
# Etiqueta cada ejecución en la BD para el versus de benchmarking.
# Valores: local | cloud
ENVIRONMENT=local
